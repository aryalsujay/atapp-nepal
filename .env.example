# Example environment variables for the Dhamma AT App.
# Copy to `.env.local` and adjust per-environment.
# Only variables prefixed with `EXPO_PUBLIC_` are exposed to the JS bundle.

# Course scraper — set to "false" to disable upstream sync (e.g. for offline demos)
EXPO_PUBLIC_ENABLE_SCRAPER=true

# Dhamma.org schedules base URL. Leave blank to use the default.
EXPO_PUBLIC_DHAMMA_BASE_URL=https://www.dhamma.org

# Future: central sync API endpoint (Phase F of 00-data-layer.md)
# EXPO_PUBLIC_SYNC_API_URL=https://api.example.org

# Feature flags
EXPO_PUBLIC_FEATURE_REAL_AUTH=false
EXPO_PUBLIC_FEATURE_PUSH_NOTIFS=false
